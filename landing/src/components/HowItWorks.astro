<section class="py-24 bg-[#111118]">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-4">How It Works</h2>
    <p class="text-gray-400 text-center mb-16 max-w-xl mx-auto">Learn AI algorithms the way they were meant to be experienced — interactively.</p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {[
        {
          icon: '📚',
          title: 'Pick a Chapter',
          description: 'Browse all 29 chapters of AIMA 4th Edition, organized by part. Each chapter has its own standalone interactive app.',
        },
        {
          icon: '🎮',
          title: 'Explore Interactively',
          description: 'Run algorithms step-by-step, tweak parameters, and see how changes affect the outcome in real time with full playback controls.',
        },
        {
          icon: '💡',
          title: 'Understand Deeply',
          description: 'Every visualization includes KaTeX-rendered math, a state inspection panel, and concise explanations tied directly to the textbook.',
        },
      ].map((item, i) => (
        <div
          class="flex flex-col items-center text-center p-8 rounded-xl bg-[#1A1A24] border border-white/5 hover:border-indigo-500/20 transition-all duration-300 hover:-translate-y-1"
          data-how-step={i}
        >
          <div class="text-5xl mb-6" aria-hidden="true">{item.icon}</div>
          <h3 class="text-xl font-semibold text-white mb-3">{item.title}</h3>
          <p class="text-gray-400 leading-relaxed">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
