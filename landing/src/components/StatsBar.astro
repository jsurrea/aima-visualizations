---
import { CHAPTERS } from '../data/chapters';

const chapters = CHAPTERS.filter(ch => !ch.isAppendix);
const appendices = CHAPTERS.filter(ch => ch.isAppendix);
const totalVisualizations = CHAPTERS.reduce((sum, ch) => sum + ch.visualizationCount, 0);
---
<section class="py-12 bg-[#111118] border-y border-white/5">
  <div class="max-w-5xl mx-auto px-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      {[
        { value: `${String(chapters.length)} Chapters + ${String(appendices.length)} Appendices`, label: 'Coverage', suffix: '' },
        { value: String(totalVisualizations), label: 'Visualizations', suffix: '' },
        { value: '7', label: 'Parts', suffix: '' },
        { value: 'Open', label: 'Source', suffix: '' },
      ].map(stat => (
        <div class="text-center p-6 rounded-xl bg-[#1A1A24] border border-white/5 hover:border-indigo-500/30 transition-colors duration-200">
          <div class="text-3xl md:text-4xl font-bold text-indigo-400 mb-1" data-count-target={stat.value}>
            {stat.value}{stat.suffix}
          </div>
          <div class="text-gray-400 text-sm font-medium">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
