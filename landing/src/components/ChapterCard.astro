---
import type { ChapterData } from '../data/chapters';

interface Props {
  chapter: ChapterData;
}

const { chapter } = Astro.props;

const statusColors: Record<string, string> = {
  complete: 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20',
  'in-progress': 'bg-amber-500/10 text-amber-400 border-amber-500/20',
  planned: 'bg-gray-500/10 text-gray-400 border-gray-500/20',
};
const statusLabels: Record<string, string> = {
  complete: '✓ Complete',
  'in-progress': '⟳ In Progress',
  planned: '◷ Planned',
};

const isAvailable = chapter.status !== 'planned';
const baseUrl = '/aima-visualizations';
---
<article
  class="group relative flex flex-col rounded-xl bg-[#111118] border border-white/5 hover:border-opacity-30 transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl overflow-hidden"
  style={`--chapter-color: ${chapter.color}; border-color: color-mix(in srgb, ${chapter.color} 0%, rgba(255,255,255,0.05));`}
  data-chapter-part={String(chapter.part)}
  data-chapter-title={chapter.title.toLowerCase()}
  data-chapter-desc={chapter.description.toLowerCase()}
>
  <!-- Color accent bar -->
  <div class="h-1 w-full" style={`background: ${chapter.color};`}></div>

  <div class="flex flex-col flex-1 p-6">
    <!-- Header: number badge + status -->
    <div class="flex items-start justify-between mb-4">
      <div class="flex items-center gap-3">
        <div
          class="flex items-center justify-center w-10 h-10 rounded-lg text-white text-sm font-bold"
          style={`background: ${chapter.color}20; color: ${chapter.color};`}
          aria-label={`Chapter ${chapter.id}`}
        >
          {String(chapter.id).padStart(2, '0')}
        </div>
        <span class="text-2xl" aria-hidden="true">{chapter.icon}</span>
      </div>
      <span class={`px-2.5 py-1 rounded-full text-xs font-medium border ${statusColors[chapter.status] ?? statusColors['planned']}`}>
        {statusLabels[chapter.status] ?? statusLabels['planned']}
      </span>
    </div>

    <!-- Title -->
    <h3 class="text-lg font-semibold text-white mb-2 leading-snug">{chapter.title}</h3>

    <!-- Description -->
    <p class="text-sm text-gray-400 leading-relaxed flex-1 mb-4">{chapter.description}</p>

    <!-- Tech stack pills -->
    <div class="flex flex-wrap gap-1.5 mb-4" aria-label="Tech stack">
      {chapter.techStack.map(tech => (
        <span class="px-2 py-0.5 rounded-md bg-white/5 text-gray-400 text-xs font-medium">{tech}</span>
      ))}
    </div>

    <!-- Footer: viz count + link -->
    <div class="flex items-center justify-between pt-3 border-t border-white/5">
      <span class="text-xs text-gray-500">{chapter.visualizationCount} visualizations</span>
      {isAvailable ? (
        <a
          href={`${baseUrl}${chapter.urlPath}/`}
          class="inline-flex items-center gap-1 px-4 py-1.5 rounded-lg text-sm font-medium text-white transition-all duration-200 hover:gap-2 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-[#111118]"
          style={`background: ${chapter.color}20; color: ${chapter.color};`}
          aria-label={`Explore Chapter ${chapter.id}: ${chapter.title}`}
        >
          Explore →
        </a>
      ) : (
        <button
          class="inline-flex items-center gap-1 px-4 py-1.5 rounded-lg text-sm font-medium text-gray-500 bg-white/5 cursor-not-allowed"
          disabled
          title="Coming soon"
          aria-label={`Chapter ${chapter.id} is planned — coming soon`}
          aria-disabled="true"
        >
          Coming Soon
        </button>
      )}
    </div>
  </div>

  <!-- Hover glow effect -->
  <div
    class="absolute inset-0 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"
    style={`box-shadow: inset 0 0 0 1px ${chapter.color}30;`}
    aria-hidden="true"
  ></div>
</article>
