---
import '../styles/global.css';
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Interactive visualizations for AI: A Modern Approach, 4th Edition.' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/aima-visualizations/favicon.svg" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="bg-[#0A0A0F] text-white min-h-screen">
    <slot />
  </body>
</html>
